    // Mostrar panel
    const panel = document.getElementById('panel-usuario');
// Mostrar panel del usuario
function showUserPanel() {
    const user = JSON.parse(localStorage.getItem('usuarioActual'));
    if (!user) {
        openLoginModal();
        return;
    }
    
    document.getElementById('panelUserName').textContent = user.nombre;
    document.getElementById('panelUserEmail').textContent = user.email;
    
    const tipoTexto = {
        'docente': 'Docente/Autoridad/Personal',
        'padre': 'Padre/Madre',
        'estudiante': 'Estudiante'
    };
    document.getElementById('panelUserType').textContent = tipoTexto[user.tipo] || user.tipo;
    
    const panel = document.getElementById('panel-usuario');
    panel.style.display = 'block';
    panel.scrollIntoView({ behavior: 'smooth' });
}

// Cerrar sesión
function logout() {
    localStorage.removeItem('usuarioActual');
    checkUserStatus();
    document.getElementById('panel-usuario').style.display = 'none';
    window.location.href = '#inicio';
    alert('Sesión cerrada correctamente.');
}

// Star Rating
const stars = document.querySelectorAll('.stars i');
let ratingValue = 0;

if (stars.length > 0) {
    stars.forEach(star => {
        star.addEventListener('click', function() {
            ratingValue = this.getAttribute('data-value');
            updateStars();
        });
        
        star.addEventListener('mouseover', function() {
            const value = this.getAttribute('data-value');
            highlightStars(value);
        });
        
        star.addEventListener('mouseout', function() {
            updateStars();
        });
    });
}

function highlightStars(value) {
    stars.forEach(star => {
        if (star.getAttribute('data-value') <= value) {
            star.classList.remove('far');
            star.classList.add('fas');
        } else {
            star.classList.remove('fas');
            star.classList.add('far');
        }
    });
}

function updateStars() {
    stars.forEach(star => {
        if (star.getAttribute('data-value') <= ratingValue) {
            star.classList.remove('far');
            star.classList.add('fas');
        } else {
            star.classList.remove('fas');
            star.classList.add('far');
        }
    });
}

