// Educar para Transformar — Campus virtual
// Schema con auth, calificaciones, vínculo padre-hijo, asistencia,
// pagos, anuncios, notificaciones, mensajería, actividades y planes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ESTUDIANTE
  DOCENTE
  PADRE
  ADMIN
}

enum AttendanceStatus {
  PRESENTE
  AUSENTE
  TARDE
  JUSTIFICADO
}

enum ActivityType {
  ACTIVIDAD
  TRABAJO
  PARCIAL
  TAREA
}

enum SubmissionStatus {
  PENDIENTE
  ENTREGADO
  CALIFICADO
}

enum PaymentStatus {
  PENDIENTE
  PAGADO
  VENCIDO
}

enum AnnouncementTarget {
  ALL
  ESTUDIANTE
  DOCENTE
  PADRE
}

model User {
  id        Int      @id @default(autoincrement())
  usuario   String   @unique
  email     String   @unique
  dni       String   @unique
  password  String
  role      Role
  nombre    String
  curso     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  notasRecibidas Grade[]             @relation("EstudianteGrades")
  notasDadas     Grade[]             @relation("DocenteGrades")
  hijos          ParentStudentLink[] @relation("PadreLinks")
  padres         ParentStudentLink[] @relation("EstudianteLinks")

  asistencias           Attendance[]
  pagosEstudiante       Payment[]      @relation("PaymentStudent")
  pagosPadre            Payment[]      @relation("PaymentParent")
  anunciosCreados       Announcement[]
  notificaciones        Notification[]
  mensajesEnviados      Message[]      @relation("MsgSender")
  mensajesRecibidos     Message[]      @relation("MsgReceiver")
  actividadesCreadas    Activity[]     @relation("ActivityDocente")
  entregas              Submission[]
  planesDeEstudio       StudyPlan[]

  @@index([role])
}

model Grade {
  id           Int      @id @default(autoincrement())
  estudianteId Int
  estudiante   User     @relation("EstudianteGrades", fields: [estudianteId], references: [id], onDelete: Cascade)
  docenteId    Int
  docente      User     @relation("DocenteGrades", fields: [docenteId], references: [id], onDelete: Restrict)
  materia      String
  instancia    String
  nota         Int
  fecha        DateTime @db.Date
  createdAt    DateTime @default(now())

  @@index([estudianteId])
  @@index([docenteId])
}

model ParentStudentLink {
  id           Int  @id @default(autoincrement())
  padreId      Int
  padre        User @relation("PadreLinks", fields: [padreId], references: [id], onDelete: Cascade)
  estudianteId Int
  estudiante   User @relation("EstudianteLinks", fields: [estudianteId], references: [id], onDelete: Cascade)

  @@unique([padreId, estudianteId])
  @@index([estudianteId])
}

model Attendance {
  id           Int              @id @default(autoincrement())
  estudianteId Int
  estudiante   User             @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  fecha        DateTime         @db.Date
  status       AttendanceStatus
  materia      String?
  observacion  String?
  createdAt    DateTime         @default(now())

  @@unique([estudianteId, fecha, materia])
  @@index([estudianteId])
  @@index([fecha])
}

model Payment {
  id           Int           @id @default(autoincrement())
  estudianteId Int
  estudiante   User          @relation("PaymentStudent", fields: [estudianteId], references: [id], onDelete: Cascade)
  padreId      Int?
  padre        User?         @relation("PaymentParent", fields: [padreId], references: [id], onDelete: SetNull)
  concepto     String
  monto        Decimal       @db.Decimal(10, 2)
  vencimiento  DateTime      @db.Date
  pagadoEn     DateTime?
  status       PaymentStatus @default(PENDIENTE)
  createdAt    DateTime      @default(now())

  @@index([estudianteId])
  @@index([status])
}

model Announcement {
  id         Int                @id @default(autoincrement())
  authorId   Int
  author     User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  titulo     String
  contenido  String
  targetRole AnnouncementTarget @default(ALL)
  createdAt  DateTime           @default(now())

  @@index([targetRole])
  @@index([createdAt])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  titulo    String
  contenido String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  sender     User     @relation("MsgSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId Int
  receiver   User     @relation("MsgReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  contenido  String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId, receiverId])
  @@index([receiverId, isRead])
}

model Activity {
  id           Int          @id @default(autoincrement())
  docenteId    Int
  docente      User         @relation("ActivityDocente", fields: [docenteId], references: [id], onDelete: Cascade)
  materia      String
  titulo       String
  descripcion  String
  tipo         ActivityType @default(TAREA)
  fechaEntrega DateTime
  maxScore     Int          @default(10)
  fileUrl      String?
  createdAt    DateTime     @default(now())

  submissions Submission[]

  @@index([materia])
  @@index([fechaEntrega])
}

model Submission {
  id           Int              @id @default(autoincrement())
  activityId   Int
  activity     Activity         @relation(fields: [activityId], references: [id], onDelete: Cascade)
  estudianteId Int
  estudiante   User             @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  textContent  String?
  fileUrl      String?
  status       SubmissionStatus @default(ENTREGADO)
  score        Int?
  feedback     String?
  entregadoEn  DateTime         @default(now())
  calificadoEn DateTime?

  @@unique([activityId, estudianteId])
  @@index([estudianteId])
}

model StudyPlan {
  id         Int      @id @default(autoincrement())
  docenteId  Int
  docente    User     @relation(fields: [docenteId], references: [id], onDelete: Cascade)
  materia    String
  titulo     String
  objetivos  String
  contenidos String
  fileUrl    String?
  createdAt  DateTime @default(now())

  @@index([materia])
}
