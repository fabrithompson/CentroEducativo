# ==============================================
# Backend — Educar para Transformar
# Copia este archivo a `.env` y completa los valores reales.
# `.env` está gitignoreado.
# ==============================================

# Entorno: development | production | test
NODE_ENV=development

# Puerto donde escucha la API
PORT=4000

# Origen permitido por CORS (URL del frontend en dev)
CORS_ORIGIN=http://localhost:5173

# ---------- Base de datos ----------
# Reemplazá USER, PASSWORD y DBNAME según tu instalación local.
# Si usás el superusuario que creaste durante la instalación de PostgreSQL:
DATABASE_URL=postgresql://postgres:TU_PASSWORD@localhost:5432/educar_transformar_db?schema=public

# ---------- JWT ----------
# Generá secretos largos y aleatorios (>= 32 caracteres).
# Ej: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_ACCESS_SECRET=cambiar-por-un-secreto-largo-y-aleatorio
JWT_REFRESH_SECRET=cambiar-por-otro-secreto-distinto
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- Uploads ----------
# Carpeta relativa a backend/ donde se guardan los archivos subidos
UPLOAD_DIR=uploads
# Tamaño máximo por archivo, en megabytes
MAX_UPLOAD_SIZE_MB=20

# ---------- SMTP (Nodemailer) ----------
# Dejá vacío si no vas a usar mails todavía.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Educar para Transformar <no-reply@educarparatransformar.edu.ar>"
