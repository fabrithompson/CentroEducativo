# Conexión a PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/centro_educativo

# Clave para firmar los tokens JWT (cambiar por una cadena larga y aleatoria)
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio

# Puerto donde escucha la API
PORT=4000

# Origen permitido para CORS (la URL del frontend en desarrollo)
CLIENT_ORIGIN=http://localhost:5173
